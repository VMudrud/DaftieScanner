# DaftieScanner — AWS production configuration template
#
# This file mirrors .env but is tuned for the EC2 + real-DynamoDB deployment.
# It is NOT loaded by the container directly. Use it as the source of truth
# when populating SSM Parameter Store under /daftiescanner/prod/<KEY>.
#
# Loader snippet (bash):
#   while read -r line; do
#     key=${line%%=*}; val=${line#*=}
#     [ -z "$key" ] && continue; case "$key" in \#*) continue;; esac
#     aws ssm put-parameter --name /daftiescanner/prod/$key \
#          --value "$val" --type SecureString --overwrite
#   done < .env.aws
#
# Anything tagged "SECRET" should be filled locally and never committed.

# --- AWS ---
# Region is also injected by the EC2 IMDS, but kept here for the SDK fallback.
AWS_REGION=eu-west-1
# AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY are NOT used in prod.
# The EC2 instance profile (aws_iam_role.daftiescanner_ec2) supplies creds.

# --- DynamoDB ---
# IMPORTANT: blank endpoint → SDK targets real AWS DynamoDB via the IAM role.
DAFT_DYNAMO_ENDPOINT=
DAFT_DYNAMO_SEEN_TABLE=daftiescanner_seen
DAFT_DYNAMO_CURSOR_TABLE=daftiescanner_cursor
DAFT_DYNAMO_ALERTS_TABLE=daftiescanner_alerts

# --- Scanner behavior ---
DAFT_POLL_INTERVAL_SECONDS=60
DAFT_POLL_JITTER_SECONDS=20
DAFT_BLOCK_BACKOFF_MINUTES=60
# In prod we want the cursor to resume, NOT replay everything.
DAFT_FORCE_COLD_START=false

# --- Active tenant IDs (comma-separated) ---
TENANTS_ACTIVE=1

# --- Tenant 1 ---
TENANT_1_ENABLED=true
TENANT_1_EMAIL=volfar.vlad@gmail.com
TENANT_1_SECTION=residential-to-rent
TENANT_1_RENTAL_PRICE_MIN=1000
TENANT_1_RENTAL_PRICE_MAX=5000
TENANT_1_NUM_BEDS_MIN=
TENANT_1_NUM_BEDS_MAX=
TENANT_1_STORED_SHAPE_IDS=
TENANT_1_NOTIFIERS=logging,telegram
TENANT_1_BER_RATINGS=

# --- Telegram bot ---
# SECRET — fill from @BotFather, store as SecureString in SSM.
DAFT_TELEGRAM_TOKEN=
DAFT_TELEGRAM_ADMIN_CONTACT=@Volfar

# --- Alerting ---
# Filled by Terraform: arn:aws:sns:eu-west-1:<acct>:daftiescanner-alerts
DAFT_ALERT_EMAIL=volfar.vlad@gmail.com
DAFT_ALERT_SNS_TOPIC_ARN=

# --- Metrics ---
# Enable CloudWatch metric publishing in prod.
MANAGEMENT_METRICS_EXPORT_CLOUDWATCH_ENABLED=true
